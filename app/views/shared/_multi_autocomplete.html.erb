<%#
  Parametri attesi:
  - form: l'oggetto form (es. f)
  - field: il prefisso dell'array (es. :photographer_ids)
  - label: Il testo della label (es. "Fotografi")
  - search_url: La rotta REST (es. photographers_searches_path)
  - selected_items: Collezione di oggetti già associati (es. job.photographers)
%>

<fieldset class="fieldset" data-controller="multi-autocomplete" data-multi-autocomplete-url-value="<%= search_url %>">
  <legend class="fieldset-legend"><%= label %></legend>

  <%# Contenitore dei Badge Selezionati %>
  <div data-multi-autocomplete-target="selectedContainer" class="flex flex-wrap gap-2 mb-2">
    <% selected_items.each do |item| %>
      <div class="badge badge-primary gap-2" data-id="<%= item.id %>">
        <%= item.respond_to?(:display_name) ? item.display_name : item.name %>
        <button type="button" data-action="click->multi-autocomplete#remove" class="hover:text-error text-xs font-bold">X</button>
        <input type="hidden" name="<%= form.object_name %>[<%= field %>][]" value="<%= item.id %>">
      </div>
    <% end %>
  </div>

  <%# Input di Ricerca %>
  <div class="dropdown w-full">
    <input type="text"
           class="input w-full"
           data-action="input->multi-autocomplete#search"
           data-multi-autocomplete-target="input"
           autocomplete="off"
           placeholder="Cerca o aggiungi nuovo...">

    <div data-multi-autocomplete-target="results" class="dropdown-content w-full z-[1]"></div>
  </div>

  <%# Template nascosto usato dal JS per generare nuovi badge al volo %>
  <template data-multi-autocomplete-target="badgeTemplate">
    <div class="badge badge-primary gap-2" data-id="TEMPLATE_ID">
      TEMPLATE_NAME
      <button type="button" data-action="click->multi-autocomplete#remove" class="hover:text-error text-xs font-bold">X</button>
      <input type="hidden" name="<%= form.object_name %>[<%= field %>][]" value="TEMPLATE_ID">
    </div>
  </template>
</fieldset>
