<%# app/views/shared/command_palette/_container.html.erb %>
<%# Variables: frame_id, max_height (optional, default: "400px"), footer_action (optional block) %>

<%= turbo_frame_tag frame_id do %>
  <%# Contenitore esterno (se usato in un modale o dropdown) %>
  <div class="flex flex-col w-full bg-base-100 rounded-xl shadow-2xl ring-1 ring-base-content/5 overflow-hidden z-[100]">

    <%# Area Scorrevole %>
    <div class="py-2 flex flex-col flex-1 overflow-y-auto overscroll-contain" style="max-height: <%= local_assigns[:max_height] || '400px' %>;">
      <%= yield %>
    </div>

    <%# Footer Condizionale (Stile Linear) %>
    <% if content_for?(:command_palette_footer) %>
      <div class="shrink-0 bg-base-200/50 p-3 border-t border-base-200 flex items-center justify-between text-xs text-base-content/60">

        <%# Lato Sinistro: Azione (es. Crea Nuovo) %>
        <div class="flex items-center gap-2">
          <%= yield :command_palette_footer %>
        </div>

        <%# Lato Destro: Suggerimenti Tastiera %>
        <div class="hidden sm:flex items-center gap-3">
          <span class="flex items-center gap-1"><kbd class="kbd kbd-xs">↑</kbd><kbd class="kbd kbd-xs">↓</kbd> naviga</span>
          <span class="flex items-center gap-1"><kbd class="kbd kbd-xs">↵</kbd> seleziona</span>
        </div>
      </div>
    <% end %>

  </div>
<% end %>
