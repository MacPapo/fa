<%#
Parametri attesi:
- id: l'ID HTML del dialog (es. "new_location_modal")
- title: Il titolo da mostrare (es. "Nuova Location")
%>
<dialog id="<%= id %>" class="modal">
    <div class="modal-box">
	<h3 class="font-bold text-lg"><%= title %></h3>

	<div class="mt-4">
	    <%= yield %>
	</div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>chiudi</button></form>
</dialog>
