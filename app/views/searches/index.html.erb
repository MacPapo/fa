<%= turbo_frame_tag "omnibox_results" do %>
  <% if @query.length >= 2 %>
    <div class="py-2 flex flex-col max-h-[60vh] overflow-y-auto overscroll-contain">

      <%# --- SEZIONE CONTATTI --- %>
      <% if @contacts.any? %>
        <%= render layout: "shared/command_palette/group", locals: { title: "Contatti", icon_name: "contacts" } do %>
          <% @contacts.each do |contact| %>
            <%= render "shared/command_palette/item",
                       url: contact_path(contact),
                       stimulus_data: { keyboard_nav_target: "item", turbo_frame: "_top" },
                       main_text: contact.display_name,
                       sub_text: contact.company_name.presence || "Privato",
                       badge: content_tag(:div, contact.kind == 1 ? "Azienda" : "Persona", class: "badge badge-ghost badge-sm") %>
          <% end %>
        <% end %>
      <% end %>

      <%# --- SEZIONE LOCATION --- %>
      <% if @locations.any? %>
        <%= render layout: "shared/command_palette/group", locals: { title: "Posizioni", icon_name: "locations" } do %>
          <% @locations.each do |location| %>
            <%= render "shared/command_palette/item",
                       url: location_path(location),
                       stimulus_data: { keyboard_nav_target: "item", turbo_frame: "_top" },
                       main_text: location.name,
                       sub_text: location.district %>
          <% end %>
        <% end %>
      <% end %>

      <%# --- SEZIONE LAVORI --- %>
      <% if @jobs.any? %>
        <%= render layout: "shared/command_palette/group", locals: { title: "Lavori & Servizi", icon_name: "calendar" } do %>
          <% @jobs.each do |job| %>
            <%= render "shared/command_palette/item",
                       url: job_path(job),
                       stimulus_data: { keyboard_nav_target: "item", turbo_frame: "_top" },
                       main_text: job.display_title,
                       sub_text: job.display_location.presence || "Nessuna posizione",
                       badge: content_tag(:div, job.date.strftime("%d/%m/%Y"), class: "text-xs font-mono bg-base-200 px-2 py-1 rounded-md text-base-content/70") %>
          <% end %>
        <% end %>
      <% end %>

      <%# --- NESSUN RISULTATO --- %>
      <% if @contacts.empty? && @locations.empty? && @jobs.empty? %>
        <%= render "shared/command_palette/empty_state", query: @query %>
      <% end %>

    </div>
  <% end %>
<% end %>
