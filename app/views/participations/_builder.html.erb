<%# app/views/participations/_builder.html.erb %>

<% frame_id = local_assigns[:wrapper_id] || "participation_builder_#{role}_#{SecureRandom.hex(4)}" %>
<% target_list_id = local_assigns[:target_list_id] || "participations-list-#{role}-#{SecureRandom.hex(4)}" %>

<%# L'URL di ricerca deve sapere due cose: che stiamo cercando per un Job (context) e quale ruolo cerchiamo (role) %>
<% search_url = local_assigns[:search_url] || contacts_searches_path(context: 'jobs', role: role) %>

<%#
Dobbiamo distinguere gli eventi. Se ho creato un "fotografo",
solo il builder dei fotografi deve reagire e aggiungere la riga.
%>
<% created_event = "contact:created:#{role}" %>

<fieldset class="fieldset"
          data-controller="multi-autocomplete nested-form"
          data-action="<%= created_event %>@window->nested-form#addFromEvent <%= created_event %>@window->multi-autocomplete#clearInput">

  <legend class="fieldset-legend"><%= label %></legend>

  <%# 1. LA LISTA %>
  <div id="<%= target_list_id %>"
       data-multi-autocomplete-target="selectedContainer"
       data-nested-form-target="list"
       class="flex flex-col gap-2 mb-4">

    <% role_participations = form.object.participations.select { |p| p.role == role } %>

    <%= form.fields_for :participations, role_participations do |p_form| %>
      <%= render 'participations/row', form: p_form, template: false %>
    <% end %>
  </div>

  <%# 2. RICERCA E DROPDOWN %>
  <div class="dropdown w-full relative" data-controller="keyboard-nav">
    <input type="text"
           class="input input-bordered w-full"
           data-multi-autocomplete-target="input"
           data-controller="autosubmit"
           data-action="input->autosubmit#submit keydown.enter->autosubmit#prevent keydown->keyboard-nav#navigate"
           data-url="<%= search_url %>"
           data-frame-id="<%= frame_id %>"
           autocomplete="off"
           placeholder="Cerca o aggiungi <%= label.downcase %>...">

    <div class="dropdown-content absolute w-full z-[100] mt-1">
      <%= turbo_frame_tag frame_id %>
    </div>
  </div>

  <%# 3. IL TEMPLATE NASCOSTO %>
  <template data-multi-autocomplete-target="badgeTemplate" data-nested-form-target="template">
    <%#
    ATTENZIONE: Qui passiamo il ruolo al nuovo record!
    Così quando viene salvato, sa già se è un fotografo o un cliente.
    %>
    <%= form.fields_for :participations, Participation.new(role: role), child_index: "NEW_RECORD" do |p_form| %>
      <%= render 'participations/row', form: p_form, template: true %>
    <% end %>
  </template>

</fieldset>
