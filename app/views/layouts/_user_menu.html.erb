<div class="dropdown dropdown-end">
  <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar avatar-placeholder">
    <div class="bg-neutral text-neutral-content w-16 rounded-full">
      <span class="text-xl">
	<%= Current.user.avatar %>
      </span>
    </div>
  </div>

  <ul
    tabindex="-1"
    class="menu menu-sm dropdown-content bg-base-100 rounded-box z-1 mt-3 w-52 p-2 shadow">

    <li>
      <%= link_to Current.user do %>
	<%= icon("admin", classes: "w-4 h-4") %>
	<span>Profilo</span>
      <% end %>
    </li>

    <li>
      <%= link_to session_path,  class: "text-error hover:bg-error/10", data: { turbo_method: :delete } do %>
	<%= icon("logout", classes: "w-4 h-4") %>
	<span>Esci</span>
      <% end %>
    </li>
  </ul>
</div>
