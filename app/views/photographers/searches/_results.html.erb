<ul class="menu bg-base-100 rounded-box shadow mt-1 w-full border border-base-300">
  <% if contacts.any? %>
    <% contacts.each do |contact| %>
      <li>
        <button type="button"
                data-action="click->multi-autocomplete#select"
                data-id="<%= contact.id %>"
                data-name="<%= contact.display_name %>">
          <div class="flex flex-col items-start">
            <span class="font-bold"><%= contact.display_name %></span>
            <% if contact.phone.present? || contact.email.present? %>
              <span class="opacity-50 text-xs">
                <%= [contact.phone, contact.email].compact_blank.join(" • ") %>
              </span>
            <% end %>
          </div>
        </button>
      </li>
    <% end %>

    <div class="divider my-0"></div>
  <% end %>

  <% if params[:query].present? %>
    <li>
      <button type="button" class="text-primary font-bold"
              data-action="click->multi-autocomplete#openModal"
              data-query="<%= params[:query] %>"
              data-modal-id="new_photographer_modal"
              data-input-id="modal_photographer_name">
        + Nuovo Fotografo: "<%= params[:query] %>"
      </button>
    </li>
  <% end %>
</ul>
