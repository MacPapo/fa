<li id="<%= dom_id job %>" class="list-row group hover:bg-base-200/50 transition-colors relative items-center">

  <%# Avatar / Badge Data %>
  <div>
    <div class="avatar avatar-placeholder">
      <div class="bg-primary/10 text-primary w-10 rounded-box flex flex-col items-center justify-center">
        <span class="text-sm font-bold leading-none"><%= job.date.strftime("%d") %></span>
        <span class="text-[10px] uppercase font-semibold leading-none mt-0.5"><%= job.date.strftime("%b") %></span>
      </div>
    </div>
  </div>

  <div class="list-col-grow min-w-0">

    <div class="flex items-center gap-2 min-w-0">
      <%= link_to truncate(job.display_title, length: 70),
		  job_path(job),
		  class: "font-semibold truncate before:absolute before:inset-0 before:z-0",
		  title: job.display_title,
		  data: {
		    turbo_frame: "_top"
		  }
      %>

      <% if job.with_video? %>
        <span class="badge badge-neutral badge-xs opacity-60 relative z-0 shrink-0">Video</span>
      <% end %>
    </div>

    <div class="text-xs opacity-60 truncate flex items-center gap-1 mt-0.5">
      <%= icon("location", classes: "size-3 shrink-0") %>
      <span class="truncate">
        <%= job.try(:display_location).presence || "Location da definire" %>
      </span>
    </div>
  </div>

  <%# Colonna Destra: Data completa e Ora (nascosta su mobile) %>
  <div class="hidden sm:flex flex-col text-right justify-center pr-4 min-w-32">

    <div class="font-mono text-sm opacity-80">
      <%= job.date.strftime("%d/%m/%Y") %>
    </div>

    <div class="text-[10px] uppercase font-semibold opacity-40">
      <% if job.start_at.present? %>
        <%= job.start_at.strftime("%H:%M") %>
      <% elsif defined?(job.legacy_from_time) && job.legacy_from_time.present? %>
        <%= job.legacy_from_time.strftime("%H:%M") %> (legacy)
      <% else %>
        —
      <% end %>
    </div>
  </div>

  <%# Azioni (Visibili all'hover su desktop, sempre visibili su mobile) %>
  <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 sm:opacity-0 opacity-100 transition-opacity relative z-10">

    <%= link_to edit_job_path(job),
		class: "btn btn-square btn-ghost btn-sm",
		data: {
		  turbo_frame: "_top"
		} do %>
      <%= icon("edit", classes: "size-4 opacity-50") %>
    <% end %>

    <%= button_to job_path(job),
		  method: :delete,
		  class: "btn btn-square btn-ghost btn-sm hover:text-error",
		  form: {
		    data: {
		      turbo_frame: "_top",
		      turbo_confirm: "Eliminare il servizio?"
		    }
		  } do %>
      <%= icon("trash", classes: "size-4 opacity-50") %>
    <% end %>
  </div>

</li>
