<%= turbo_stream_from @user %>

<div id="<%= dom_id(@user) %>" class="max-w-4xl mx-auto pb-12 px-4 sm:px-6 lg:px-8 mt-8 lg:mt-12">

  <%# HEADER ENTITÀ - Trasformato in Card %>
  <div class="bg-base-100 p-6 sm:p-8 rounded-2xl shadow-sm border border-base-200 mb-10 flex flex-col sm:flex-row sm:items-center justify-between gap-6">
    <div class="flex items-center gap-5 flex-1 min-w-0">

      <div class="avatar avatar-placeholder shrink-0">
        <div class="bg-primary text-primary-content rounded-full w-16 h-16 sm:w-20 sm:h-20 shadow-inner">
          <span class="text-2xl sm:text-3xl font-bold"><%= @user.display_name.first(2).upcase %></span>
        </div>
      </div>

      <div class="flex flex-col min-w-0">
        <h1 class="text-2xl sm:text-3xl font-extrabold break-words truncate tracking-tight">
          @<%= @user.display_name %>
        </h1>
        <div class="text-sm opacity-60 mt-1 flex items-center gap-2">
          <div class="badge badge-primary badge-sm badge-outline">Utente Sistema</div>
          <span>Gestione Profilo</span>
        </div>
      </div>

    </div>

    <div class="flex items-center gap-2 shrink-0">
      <%# AGGIUNTO IL TURBO_FRAME PER APRIRE IL MODALE %>
      <%= link_to edit_user_path(@user), class: "btn btn-primary", data: { turbo_frame: "modal" } do %>
        <%= icon("edit", classes: "size-4 sm:size-5") %>
        <span>Modifica Profilo</span>
      <% end %>
    </div>
  </div>

  <%# BODY: Sessioni %>
  <div class="flex flex-col gap-5">

    <%# Intestazione Sezione %>
    <div class="flex items-end justify-between px-1">
      <div>
        <h2 class="text-xl font-bold">Dispositivi Connessi</h2>
        <p class="text-sm opacity-60 mt-0.5">Sessioni di accesso attive collegate a questo account.</p>
      </div>
      <div class="badge badge-neutral"><%= @user.sessions.size %> attive</div>
    </div>

    <%# Lista Sessioni - Stile Card Moderno %>
    <div class="bg-base-100 rounded-2xl shadow-sm border border-base-200 overflow-hidden">
      <ul class="list">

        <% if @user.sessions.any? %>
          <% @user.sessions.sort_by(&:created_at).reverse.each do |session| %>

            <li class="list-row items-center p-4 sm:px-6 hover:bg-base-200/50 transition-colors border-b border-base-200/60 last:border-0">

              <div class="avatar shrink-0">
                <div class="w-12 h-12 flex items-center justify-center bg-base-200 text-base-content/60 rounded-xl">
                  <%= icon("monitor_smartphone", classes: "size-6") %>
                </div>
              </div>

              <div class="flex-1 min-w-0 ml-4">
                <div class="font-bold text-sm truncate" title="<%= session.user_agent %>">
                  <%= session.user_agent.presence || "Dispositivo Sconosciuto" %>
                </div>

                <div class="text-xs opacity-60 flex items-center gap-2 mt-1">
                  <span class="flex items-center gap-1 font-mono">
                    IP: <%= session.ip_address.presence || "N/D" %>
                  </span>
                  <span>&bull;</span>
                  <span><%= time_ago_in_words(session.created_at) %> fa</span>
                </div>
              </div>

            </li>
          <% end %>

        <% else %>
          <li class="p-10 flex flex-col items-center justify-center text-center opacity-50">
            <%= icon("shield", classes: "size-10 mb-3 opacity-20") %>
            <span class="text-sm italic">Nessuna sessione registrata.</span>
          </li>
        <% end %>

      </ul>
    </div>
  </div>

</div>
